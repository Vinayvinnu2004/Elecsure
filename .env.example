# ════════════════════════════════════════════════════════════════════
#  ElecSure — Environment Configuration
#  Copy to .env and fill in ALL values before running.
# ════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────
APP_NAME=ElecSure
DEBUG=false
BASE_URL=http://localhost:8000

# ── Security (REQUIRED) ──────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-min-32-chars-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── MySQL Database (REQUIRED) ────────────────────────────────────────
# You need to create the database first:
#   CREATE DATABASE elecsure CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=elecsure
DATABASE_URL=mysql+aiomysql://root:your-mysql-password@127.0.0.1:3306/elecsure

# ── Admin Credentials (auto-created on first run) ─────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_secure_password
ADMIN_NAME=Admin User

# ── Stripe Payments ──────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Email (SMTP) ─────────────────────────────────────────────────────
# Gmail example: enable "App Passwords" in Google Account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@elecsure.com
EMAIL_FROM_NAME=ElecSure


# --  AI (Chatbot) ----------------------------------------
# Get from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# -- OTP Settings -------------------------------------------------------
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_EMAIL_LINK_ENABLED=true
SUPPORT_PHONE=+91-0000000000


# -- Google OAuth 2.0 -------------------------------------------------
# 1. Go to https://console.cloud.google.com
# 2. APIs & Services  Credentials  Create OAuth 2.0 Client ID
# 3. App type: Web application
# 4. Authorised redirect URI: http://localhost:8000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# -- External SMS Service (Twilio) -------------------------------------
# Get from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=



